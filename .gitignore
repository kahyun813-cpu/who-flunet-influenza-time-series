# R session and history files
.Rhistory
.RData
.Ruserdata

# RStudio project files
.Rproj.user/

# Operating system files
.DS_Store
Thumbs.db

# Raw and processed data are usually excluded from GitHub.
# Keep the folder structure with README files.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Generated outputs
figures/*
tables/*
reports/*
!figures/.gitkeep
!tables/.gitkeep
!reports/.gitkeep

# Logs and temporary files
*.log
*.tmp
*.bak
